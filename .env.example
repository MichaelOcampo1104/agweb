# ============================================================================
# Environment variables for the Sourcify B2B data aggregation platform.
# Copy this file to `.env` (at the repo root) and fill in your own values.
# ============================================================================

# ---- Next.js (web) --------------------------------------------------------
# Public, safe-to-expose values. Find them in Supabase Dashboard →
# Project Settings → API → "Project URL" and the "anon public" key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Canonical site URL — used by sitemap.ts / robots.ts / canonical links.
# Set this to your real production domain. If unset in production, the build
# warns: URLs would resolve to localhost and Google would NOT index the site.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# ---- Python scrapers ------------------------------------------------------
# The SERVICE ROLE key. Scrapers MUST use this — the anon key has no write
# access by design (RLS). Keep it secret; never expose it to the browser.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
